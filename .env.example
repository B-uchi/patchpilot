# ─────────────────────────────────────────────────────────────────────────────
# .env.example
#
# FOR LOCAL TESTING ONLY — copy this to .env and fill it in.
#
# When PatchPilot runs inside GitLab CI, none of these are needed except
# ANTHROPIC_API_KEY and PATCHPILOT_TOKEN (which you set in the GitLab UI).
# GitLab automatically provides everything else at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required in CI (set in GitLab UI: Settings → CI/CD → Variables) ─────────

# Your Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# A GitLab Personal Access Token with "api" scope
# Create at: GitLab → User Settings → Access Tokens
PATCHPILOT_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx


# ── Required ONLY for local testing (not needed in CI) ───────────────────────
# In CI, GitLab injects CI_PROJECT_ID and CI_SERVER_URL automatically.
# These are only needed when running: npm run test:local

# The GitLab project to open MRs on during local testing
# Format: "namespace/project-name"  e.g. "mybusiness/my-app"
GITLAB_PROJECT_ID=your-namespace/your-project

# Your GitLab instance — only change if you're self-hosted
GITLAB_BASE_URL=https://gitlab.com


# ── Optional overrides ────────────────────────────────────────────────────────

# Minimum severity to act on: critical | high | medium | low  (default: high)
MIN_SEVERITY=high

# Set to "true" to run without opening real branches or MRs
DRY_RUN=false
